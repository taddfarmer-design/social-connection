                        </div>
                        <div class="progress-text">5 of 5</div>
                    </div>
                    <div class="screen-body">
                        <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 12px; color: var(--text-dark);">Cohort Insights</h2>
                        <p style="font-size: 12px; color: var(--text-light); margin-bottom: 16px;">What's your classmates are discovering</p>

                        <div class="sticky-notes">
                            <div class="sticky-note sticky-blue">I didn't realize my bus driver was part of my support network</div>
                            <div class="sticky-note sticky-green">My sibling helped without me even asking</div>
                            <div class="sticky-note sticky-cream">The library staff was there the whole time</div>
                            <div class="sticky-note sticky-blue">A random comment changed my perspective</div>
                            <div class="sticky-note sticky-green">My old teacher still believes in me</div>
                            <div class="sticky-note sticky-cream">Support came from unexpected people</div>
                        </div>

                        <p style="font-size: 12px; color: var(--text-light); margin-bottom: 12px; margin-top: 20px;">Add your insight</p>
                        <div style="display: flex; gap: 8px;">
                            <textarea placeholder="What's something you realized?" style="flex: 1; padding: 10px 12px; border: 2px solid #DDD; border-radius: 8px; font-size: 12px; font-family: 'Plus Jakarta Sans', sans-serif; resize: vertical; min-height: 60px;"></textarea>
                        </div>
                    </div>

                    <button class="btn btn-primary" onclick="goToScreen('knowledge-check-1')">Next</button>
                </div>

                <!-- Screen 14: Knowledge Check 1 -->
                <div class="screen" id="screen-knowledge-check-1">
                    <div class="progress-container">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 80%"></div>
                        </div>
                        <div class="progress-text">5 of 5</div>
                    </div>
                    <div class="screen-body">
                        <div style="font-size: 12px; color: var(--text-light); font-weight: 600; margin-bottom: 16px;">Check in with yourself</div>
                        <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);">Which feels closer to how you're thinking right now?</h2>
                        <p style="font-size: 12px; color: var(--text-light); margin-bottom: 20px;">No right answer. Just notice.</p>

                        <div class="belief-card" onclick="selectBelief(this)" data-choice="a">
                            <div class="belief-card-text">I mostly move forward on my own.</div>
                        </div>

                        <div class="belief-card" onclick="selectBelief(this)" data-choice="b">
                            <div class="belief-card-text">Support is often present, even when I don't name it.</div>
                        </div>

                        <div id="beliefResponse" style="display: none; margin-top: 16px; padding: 16px; background: var(--bg-light); border-radius: 12px;"></div>
                    </div>

                    <button class="btn btn-primary" onclick="goToScreen('knowledge-check-2')">Next</button>
                </div>

                <!-- Screen 15: Knowledge Check 2 -->
                <div class="screen" id="screen-knowledge-check-2">
                    <div class="progress-container">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 90%"></div>
                        </div>
                        <div class="progress-text">5 of 5</div>
                    </div>
                    <div class="screen-body">
                        <div style="font-size: 12px; color: var(--text-light); font-weight: 600; margin-bottom: 16px;">Shift check</div>
                        <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);">How has your thinking moved?</h2>
                        <p style="font-size: 12px; color: var(--text-light); margin-bottom: 20px;">Drag the slider to where you are now.</p>

                        <div class="slider-container">
                            <input type="range" min="0" max="100" value="50" class="slider" id="thinkingSlider" onchange="updateSliderFeedback(this.value)">
                            <div class="slider-labels">
                                <span>Support only counts when someone intentionally helps.</span>
                                <span>Support can be indirect, structural, or show up in ways I didn't expect.</span>
                            </div>
                        </div>

                        <div id="sliderFeedback" style="text-align: center; margin-top: 24px; min-height: 40px;">
                            <p style="font-size: 14px; color: var(--text-dark); line-height: 1.6;"></p>
                        </div>
                    </div>

                    <button class="btn btn-primary" onclick="goToScreen('recap')">Next</button>
                </div>

                <!-- Screen 16: Recap -->
                <div class="screen" id="screen-recap">
                    <div class="progress-container">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 100%"></div>
                        </div>
                        <div class="progress-text">5 of 5 (Complete!)</div>
                    </div>
                    <div class="screen-body">
                        <div style="text-align: center;">
                            <h2 style="font-size: 24px; font-weight: 700; color: var(--text-dark); margin-bottom: 24px;">Quick recap</h2>

                            <h3 style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 16px; text-align: left;">What's already helping me keep going?</h3>

                            <div style="text-align: left;">
                                <div style="margin-bottom: 16px;">
                                    <div style="font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px;">Support is often invisible</div>
                                    <div style="font-size: 12px; color: var(--text-light); line-height: 1.6;">We don't always notice when others are helping us move forward. Slowing down to notice changes what we see.</div>
                                </div>
                                <div style="margin-bottom: 16px;">
                                    <div style="font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px;">Helpers take many forms</div>
                                    <div style="font-size: 12px; color: var(--text-light); line-height: 1.6;">Support isn't always from best friends. It comes from coworkers, teachers, neighbors, and sometimes systems we rely on.</div>
                                </div>
                                <div style="margin-bottom: 24px;">
                                    <div style="font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px;">You're not as alone as you think</div>
                                    <div style="font-size: 12px; color: var(--text-light); line-height: 1.6;">Most progress isn't solo. Looking back reveals networks we didn't know we had.</div>
                                </div>
                            </div>

                            <div style="background: var(--primary-light); border-radius: 12px; padding: 12px; margin-bottom: 24px;">
                                <div style="font-size: 12px; font-weight: 600; color: var(--primary);">Section 1 Complete!</div>
                            </div>

                            <div style="background: var(--bg-light); border-radius: 12px; padding: 16px; margin-bottom: 16px;">
                                <p style="font-size: 12px; color: var(--text-dark); margin-bottom: 12px; font-weight: 600;">Want to dig deeper?</p>
                                <button class="btn btn-secondary" style="width: 100%;">Talk it Through</button>
                            </div>

                            <svg class="swoop" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                                <path d="M200 200 C200 120, 160 80, 80 80 C40 80, 10 100, 0 140 L0 200 Z" fill="url(#swoopGrad)" opacity="0.12"/>
                                <path d="M200 200 C200 150, 170 110, 110 110 C70 110, 40 130, 20 160 L20 200 Z" fill="url(#swoopGrad)" opacity="0.08"/>
                            </svg>
                        </div>
                    </div>

                    <button class="btn btn-primary" onclick="completeModule()">Back to Hub</button>
                </div>
            </div>

            <div class="bottom-nav">
                <div class="nav-item active" onclick="goToScreen('hub'); updateNav(0)">
                    <div class="nav-icon">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M10.5 1.5H3C2.17 1.5 1.5 2.17 1.5 3v14c0 .83.67 1.5 1.5 1.5h14c.83 0 1.5-.67 1.5-1.5V9.5"/>
                            <path d="M6 11h8M6 14h5"/>
                        </svg>
                    </div>
                    <span>Home</span>
                </div>
                <div class="nav-item" onclick="updateNav(1)">
                    <div class="nav-icon">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M10 1C5.58 1 2 4.58 2 9c0 3.25 2.3 6.02 5.44 6.76.2.04.24.11.24.25v1.37c0 .2.08.31.27.31.35 0 2.5-1.73 3.42-2.35.42.06.84.09 1.28.09 4.42 0 8-3.58 8-8S14.42 1 10 1z"/>
                        </svg>
                    </div>
                    <span>Map</span>
                </div>
                <div class="nav-item" onclick="updateNav(2)">
                    <div class="nav-icon">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M3 2h14c.55 0 1 .45 1 1v14c0 .55-.45 1-1 1H3c-.55 0-1-.45-1-1V3c0-.55.45-1 1-1zm2 2v2h10V4H5zm0 4v8h10V8H5z"/>
                        </svg>
                    </div>
                    <span>Toolkit</span>
                </div>
                <div class="nav-item" onclick="updateNav(3)">
                    <div class="nav-icon">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M10 10c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V18h14v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                        </svg>
                    </div>
                    <span>Profile</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        // State management
        let currentScreen = 'welcome';
        let surveyAnswers = {};
        let selectedChips = [];

        // Navigation
        function goToScreen(screenId) {
            const screens = document.querySelectorAll('.screen');
            screens.forEach(screen => screen.classList.remove('active'));

            const targetScreen = document.getElementById(`screen-${screenId}`);
            if (targetScreen) {
                targetScreen.classList.add('active');
                currentScreen = screenId;
                document.getElementById('screenContent').scrollTop = 0;
            }
        }

        // Carousel
        function goToCarouselSlide(index) {
            const slides = document.querySelectorAll('.carousel-slide');
            const dots = document.querySelectorAll('.dot');

            slides.forEach(slide => slide.classList.remove('active'));
            dots.forEach(dot => dot.classList.remove('active'));

            slides[index].classList.add('active');
            dots[index].classList.add('active');
        }

        // Survey
        function selectLikert(button, question) {
            const container = button.parentElement;
            const buttons = container.querySelectorAll('.likert-btn');
            buttons.forEach(btn => btn.classList.remove('selected'));
            button.classList.add('selected');
            surveyAnswers[question] = button.textContent;
        }

        function submitSurvey() {
            const answered = Object.keys(surveyAnswers).length === 5;
            if (answered) {
                goToScreen('results');
            } else {
                alert('Please answer all questions');
            }
        }

        // Chips
        function toggleChip(element) {
            element.classList.toggle('selected');
            const text = element.textContent;
            if (element.classList.contains('selected')) {
                if (!selectedChips.includes(text)) selectedChips.push(text);
            } else {
                selectedChips = selectedChips.filter(chip => chip !== text);
            }
        }

        // Contact Cards
        function toggleContact(element) {
            element.classList.toggle('selected');
        }

        // Belief Selection
        function selectBelief(element) {
            const container = element.parentElement;
            const cards = container.querySelectorAll('.belief-card');
            cards.forEach(card => card.classList.remove('selected'));
            element.classList.add('selected');

            const responseDiv = document.getElementById('beliefResponse');
            responseDiv.style.display = 'block';

            if (element.dataset.choice === 'a') {
                responseDiv.innerHTML = '<p style="font-size: 14px; color: var(--text-dark); line-height: 1.6;">That\'s where a lot of people start. As you keep going, you may notice that support was there more often than you realized — just in quieter forms.</p>';
            } else {
                responseDiv.innerHTML = '<p style="font-size: 14px; color: var(--text-dark); line-height: 1.6;">That shift matters. Noticing support that\'s already present changes how you move through challenges — even before anything else changes.</p>';
            }
        }

        // Slider Feedback
        function updateSliderFeedback(value) {
            const feedback = document.getElementById('sliderFeedback');
            const val = parseInt(value);
            let message = '';
            if (val < 30) {
                message = "Still leaning toward your earlier thinking. That's okay — shifts take time.";
            } else if (val < 60) {
                message = "Somewhere in between. You're noticing new things without throwing out what you knew before.";
            } else {
                message = "You're seeing support differently now. That awareness is the foundation for everything that comes next.";
            }
            feedback.innerHTML = `<p style="font-size: 14px; color: var(--text-dark); line-height: 1.6;">${message}</p>`;
        }

        // Complete Module
        function completeModule() {
            goToScreen('hub');
        }

        // Navigation Update
        function updateNav(index) {
            const navItems = document.querySelectorAll('.nav-item');
            navItems.forEach(item => item.classList.remove('active'));
            navItems[index].classList.add('active');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            goToCarouselSlide(0);
            updateSliderFeedback(50);
        });
    </script>
</body>
</html>

